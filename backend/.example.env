# ============================================
# Backend Environment Variables
# ============================================

# Database connection URL
# Locally: Use local MongoDB instance
# On Vercel: Set this in Vercel Dashboard to your MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/college_erp

# Secret key for signing JWT tokens
JWT_SECRET=college_erp_secret_key_2024

# Environment mode
NODE_ENV=development

# Server port
PORT=5000
